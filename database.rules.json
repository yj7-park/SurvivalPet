{
  "rules": {
    "rooms": {
      "$seed": {
        "players": {
          "$playerId": {
            ".read": "auth == null || auth != null",
            ".write": "auth == null || auth != null"
          }
        },
        "chat": {
          ".read": true,
          ".write": true,
          "$msgId": {
            ".validate": "newData.child('text').isString() && newData.child('text').val().length <= 60 && (newData.child('type').val() === 'user' ? newData.child('playerId').isString() : true)"
          }
        },
        "world": {
          "buildings": {
            ".read": "auth == null || auth != null",
            "$buildingId": {
              ".write": "auth == null || auth != null"
            }
          },
          "treeCuts": {
            ".read": "auth == null || auth != null",
            "$entryId": {
              ".write": "auth == null || auth != null"
            }
          },
          "rockMines": {
            ".read": "auth == null || auth != null",
            "$entryId": {
              ".write": "auth == null || auth != null"
            }
          }
        }
      }
    }
  }
}
